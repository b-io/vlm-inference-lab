# --- Mode: existing | generic ---
# 'existing': For a pod already running vLLM (e.g., via Runpod template). Uses RUNPOD_BASE_URL.
# 'generic': For a remote VM where you want to deploy vLLM over SSH. Uses RUNPOD_SSH_HOST and SSH vars.
RUNPOD_MODE=existing

# --- Example A: existing-service mode ---
# RUNPOD_MODE=existing
# RUNPOD_BASE_URL=https://<pod-id>-8000.proxy.runpod.net/v1
# MODEL_ID=opt-125m

# --- Example B: generic SSH-deploy mode ---
# RUNPOD_MODE=generic
# RUNPOD_BASE_URL=https://<pod-id>-8000.proxy.runpod.net/v1
# # Use DIRECT TCP host/port for SSH/SCP (Required for SCP/SFTP)
# # DO NOT use ssh.runpod.io shortcut here.
# RUNPOD_SSH_HOST=194.xxx.xxx.xxx
# RUNPOD_SSH_PORT=20000
# RUNPOD_SSH_USER=root
# RUNPOD_SSH_KEY_PATH=~/.ssh/id_ed25519
# MODEL_ID=facebook/opt-125m
# HF_TOKEN=
# VLLM_PORT=8000

# --- HTTP ENDPOINT (Source of truth for readiness and benchmark) ---
# RUNPOD_BASE_URL is for HTTP API traffic only.
# In 'existing' mode, MUST be the .proxy.runpod.net URL.
# In 'generic' mode, it is usually still the .proxy.runpod.net URL.
# The proxy URL provided by Runpod (e.g., https://<pod-id>-8000.proxy.runpod.net/v1)
RUNPOD_BASE_URL=https://<pod-id>-8000.proxy.runpod.net/v1

# --- SHARED CONFIGURATION ---
# Model to benchmark or deploy (e.g., facebook/opt-125m)
MODEL_ID=facebook/opt-125m

# Your Hugging Face token (required only for gated models like Llama)
HF_TOKEN=

# Port where the vLLM server will listen on the remote host
VLLM_PORT=8000

# --- GENERIC-REMOTE MODE (SSH Deployment) ---
# How to reach the pod for remote shell operations in generic mode.
# Values:
#   auto        = try direct TCP SSH first, then proxied SSH bootstrap
#   proxied     = use ssh.runpod.io only
#   direct      = require direct TCP SSH
RUNPOD_SSH_MODE=auto

# Proxied SSH target (e.g., j0axhra8c4u1mi-64411b50@ssh.runpod.io)
# Required for SSH bootstrapping if direct TCP is unavailable.
RUNPOD_PROXY_SSH_TARGET=

# RUNPOD_SSH_HOST/PORT/USER/KEY_PATH are for direct TCP SSH/SCP/SFTP only.
# Required for generic mode.
# Use the "SSH over exposed TCP" details from the Runpod Connect tab.
RUNPOD_SSH_HOST=194.68.xxx.xxx
RUNPOD_SSH_PORT=22106
RUNPOD_SSH_USER=root
RUNPOD_SSH_KEY_PATH=~/.ssh/id_ed25519

# Set to true to allow generic mode to mutate an already-running vLLM pod.
# DANGER: This may kill the main service process.
RUNPOD_ALLOW_MANAGED_INSTANCE_MUTATION=false

# --- OPTIONAL: API-ASSISTED FIELDS ---
# These are used by advanced automation scripts if available
RUNPOD_API_KEY=
RUNPOD_GPU_TYPE="A40"
RUNPOD_REGION=EU-SE-1
RUNPOD_DISK_GB=20
RUNPOD_VOLUME_GB=40
