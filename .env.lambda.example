# Lambda Labs Demo Configuration

# --- REQUIRED FOR MANUAL MODE ---
# The Public IP of your Lambda GPU instance
LAMBDA_INSTANCE_IP=

# The SSH user (usually 'ubuntu' for Lambda)
LAMBDA_SSH_USER=ubuntu

# Port for the vLLM server (default 8000)
VLLM_PORT=8000

# --- REQUIRED FOR REMOTE vLLM STARTUP ---
# Your Hugging Face token
HF_TOKEN=

# Model ID to serve
MODEL_ID=facebook/opt-125m

# --- OPTIONAL: FOR API-ASSISTED MODE ---
# Your Lambda API Key
LAMBDA_API_KEY=

# Instance Type (e.g., gpu_1x_h100, gpu_1x_a100)
LAMBDA_INSTANCE_TYPE=gpu_1x_h100

# Region (e.g., us-east-1)
LAMBDA_REGION=us-east-1
